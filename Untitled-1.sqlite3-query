--All moons
SELECT * FROM Moons;

--All moons and their planets
SELECT Planets.Name,Moons.MoonID FROM Moons
JOIN Planets ON Planets.PlanetID=Moons.PlanetID;

--Order by planets
SELECT * FROM Moons
ORDER BY PlanetID;

--Order by number of Moons
SELECT * FROM Moons
ORDER BY MoonID;